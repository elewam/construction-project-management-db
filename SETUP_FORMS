VBA Code for Form:

VBA
Private Sub Form_Load()
    ' Format form
    Me.BackColor = RGB(240, 240, 240)
End Sub

Private Sub ProjectStatus_Change()
    ' Update when status changes
    Me.Dirty = False
End Sub

Private Sub Form_BeforeUpdate(Cancel As Integer)
    ' Validate before saving
    If IsNull(Me.ProjectName) Then
        MsgBox "Project name is required!", vbCritical
        Cancel = True
    ElseIf Me.EndDate < Me.StartDate Then
        MsgBox "End date must be after start date!", vbCritical
        Cancel = True
    End If
End Sub
