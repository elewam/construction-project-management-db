7. FORM: Project Dashboard Form
Name: frmProjectDashboard Purpose: Project overview and KPIs

Controls:

List box showing active projects
Text boxes for:
Total Projects
Active Projects
Overdue Projects
Total Budget
Total Actual Cost
Budget Variance
Average Completion %
VBA
Private Sub Form_Load()
    RefreshDashboard
End Sub

Sub RefreshDashboard()
    Dim db As Database
    Dim rs As Recordset
    Set db = CurrentDb
    
    ' Total projects
    Set rs = db.OpenRecordset("SELECT COUNT(*) as cnt FROM Projects")
    Me.txtTotalProjects = rs!cnt
    rs.Close
    
    ' Active projects
    Set rs = db.OpenRecordset("SELECT COUNT(*) as cnt FROM Projects WHERE ProjectStatus='Active'")
    Me.txtActiveProjects = rs!cnt
    rs.Close
    
    ' Overdue projects
    Set rs = db.OpenRecordset("SELECT COUNT(*) as cnt FROM Projects WHERE EndDate < NOW() AND ProjectStatus<>'Completed'")
    Me.txtOverdueProjects = rs!cnt
    rs.Close
    
    ' Financial summary
    Set rs = db.OpenRecordset("SELECT SUM(BudgetAmount) as budget, SUM(ActualCost) as actual FROM Projects")
    Me.txtTotalBudget = rs!budget
    Me.txtTotalActual = rs!actual
    Me.txtVariance = rs!budget - rs!actual
    rs.Close
    
    Set rs = Nothing
    Set db = Nothing
End Sub

Private Sub cmdRefresh_Click()
    RefreshDashboard
    MsgBox "Dashboard refreshed!", vbInformation
End Sub
