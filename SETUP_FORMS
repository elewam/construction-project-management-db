9. FORM: Receivables Form
Name: frmReceivables Purpose: Track customer invoices

Fields:

ProjectID (Combo)
UnitID (Combo)
BuyerName (Text)
InvoiceNumber (Text)
Amount (Currency)
AmountPaid (Currency)
Status (Combo)
DueDate (Date)
VBA
Private Sub AmountPaid_AfterUpdate()
    Dim Outstanding As Currency
    Outstanding = Me.Amount - Me.AmountPaid
    
    If Outstanding = 0 Then
        Me.Status = "Paid"
    ElseIf Me.AmountPaid > 0 Then
        Me.Status = "Partial"
    Else
        Me.Status = "Sent"
    End If
    
    Me.txtOutstanding = Outstanding
End Sub
