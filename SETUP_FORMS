VBA
Private Sub Quantity_AfterUpdate()
    CalculateCost
End Sub

Private Sub UnitPrice_AfterUpdate()
    CalculateCost
End Sub

Private Sub CalculateCost()
    If Not IsNull(Me.Quantity) And Not IsNull(Me.UnitPrice) Then
        Me.ActualCost = Me.Quantity * Me.UnitPrice
    End If
End Sub

Private Sub Form_BeforeUpdate(Cancel As Integer)
    If Me.ActualCost > Me.BudgetAmount Then
        If MsgBox("Actual cost exceeds budget. Continue?", vbQuestion + vbYesNo) = vbNo Then
            Cancel = True
        End If
    End If
End Sub
